# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem

# ── Database (live runtime data) ──────────────────────────────────────────────
database/data/
*.db
*.sqlite
*.sqlite3

# ── User uploads (runtime, binary, potentially large) ────────────────────────
uploads/

# ── Application logs ──────────────────────────────────────────────────────────
logs/
*.log

# ── OS / editor artefacts ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# ── Pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
