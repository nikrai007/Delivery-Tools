# Copy to .env and edit. All values optional except FLASK_SECRET_KEY in production.

FLASK_SECRET_KEY=change-me-to-a-long-random-string

# â”€â”€â”€ Branding â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
PLATFORM_NAME=Delivery Toolbox
APP_NAME=AutoBackupRevert
APP_OWNER=Nikhil Kumar (EC2845)
APP_COMPANY=Personal Dev Corporation ltd

# â”€â”€â”€ Bootstrap admin (created on first run if not exists) â”€â”€â”€â”€â”€â”€â”€â”€â”€
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin

# â”€â”€â”€ Server â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
HOST=0.0.0.0
PORT=5000
# Used when generating absolute URLs for emails (password-reset link). Falls
# back to the request host if blank.
BASE_URL=

# â”€â”€â”€ Upload limits and cleanup â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
MAX_UPLOAD_MB=500
CLEANUP_MINUTES=60
JOB_RETENTION_DAYS=30
RESET_TOKEN_TTL_MINUTES=60

# â”€â”€â”€ Paths (relative to app root unless absolute) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
UPLOAD_ROOT=uploads
DATA_DIR=database/data

# â”€â”€â”€ SMTP (optional). If unset, password-reset emails are written to the
#      server console with a clear marker â€” admin can hand the link over.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=1

# â”€â”€â”€ Headless API (Bearer token, /api/v1/jobs). Toggleable from the
#      admin UI as well; this just sets the initial state.
ENABLE_API=1
